rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /performers/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /content/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /clients/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
